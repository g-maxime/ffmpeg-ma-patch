From cae23524cf6c45cc7a9ff60bc9513b98f70938c8 Mon Sep 17 00:00:00 2001
From: Jerome Martinez <jerome@mediaarea.net>
Date: Thu, 4 Jul 2024 10:45:57 +0200
Subject: [PATCH 04/17] avcodec/dpx: Fix B&W film scans from DIAMANT-Film

---
 libavcodec/dpx.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/libavcodec/dpx.c b/libavcodec/dpx.c
index 7355b50f7a..93ef27d454 100644
--- a/libavcodec/dpx.c
+++ b/libavcodec/dpx.c
@@ -613,6 +613,7 @@ static int decode_frame(AVCodecContext *avctx, AVFrame *p,
 
     // Some devices do not pad 10bit samples to whole 32bit words per row
     if (!memcmp(input_device, "Scanity", 7) ||
+        !memcmp(creator, "DIAMANT-Film", 12) ||
         !memcmp(creator, "Lasergraphics Inc.", 18)) {
         if (avctx->bits_per_raw_sample == 10)
             dpx->unpadded_10bit = 1;
